# mini-rlm 데모 실행에 필요한 키 템플릿.
# 이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.example .env

# [필수] OpenRouter API 키 — https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY=

# [RAG 비교 시 필수] OpenAI API 키 — RAG 검색 임베딩(text-embedding-3-large)용.
# python -m eval.compare 에 rag 시스템을 포함하거나 비교 페이지에서 RAG를 켤 때 필요.
OPENAI_API_KEY=

# [선택] 엔드포인트/모델 오버라이드 (없으면 기본값 사용)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# RLM_ROOT_MODEL=openai/gpt-5.6-sol     # 코드 생성용 루트 모델
# RLM_SUB_MODEL=openai/gpt-5.6-luna     # 위임용 sub 모델

# [선택] RAG 검색 파라미터 오버라이드 (없으면 기본값 사용)
# RAG_EMBED_MODEL=text-embedding-3-large
# RAG_CHUNK_SIZE=800    RAG_CHUNK_OVERLAP=150
# RAG_TOP_K=6           RAG_TOP_N=24
# RAG_USE_HYDE=true     RAG_USE_RERANK=true

# [선택] LangSmith 트레이싱 (재귀/sub-call 호출 트리를 시각화하고 싶을 때)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=mini-rlm
